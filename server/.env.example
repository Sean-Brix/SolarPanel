# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/solarpanel_demo"

# API server port
PORT=4000

# Optional Prisma pool tuning for burst MQTT ingest.
# If DATABASE_URL has a very low connection_limit, the server auto-raises it unless disabled.
PRISMA_AUTO_POOL=true
PRISMA_AUTO_POOL_MIN=4
# Optional explicit override (takes precedence over URL and auto-pool):
# PRISMA_CONNECTION_LIMIT=4

# Optional write queue cap. If unset, it is inferred from connection_limit.
# DB_WRITE_CONCURRENCY=3

# MQTT Broker Configuration (for forecast publishing to devices)
MQTT_BROKER_URL="mqtts://8c8f0dbc419240d09dfc75c1cfff9c78.s1.eu.hivemq.cloud:8883"
MQTT_USERNAME="helios"
MQTT_PASSWORD="Helios123"
MQTT_QOS=1
