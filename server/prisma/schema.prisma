generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model FixedReading {
  id                  Int      @id @default(autoincrement())
  voltage             Float
  current             Float
  power               Float
  createdAt           DateTime @default(now())
  energyKwh           Float    @default(0)
  cumulativeEnergyKwh Float    @default(0)

  @@map("fixed_readings")
}

model ConventionalReading {
  id                  Int      @id @default(autoincrement())
  voltage             Float
  current             Float
  power               Float
  axisX               Float
  axisY               Float
  axisZ               Float
  ldrTop              Int
  ldrBottom           Int
  ldrLeft             Int
  ldrRight            Int
  createdAt           DateTime @default(now())
  energyKwh           Float    @default(0)
  cumulativeEnergyKwh Float    @default(0)

  @@map("conventional_readings")
}

model AnnReading {
  id                  Int      @id @default(autoincrement())
  voltage             Float
  current             Float
  power               Float
  axisX               Float
  axisY               Float
  axisZ               Float
  ldrTop              Int
  ldrBottom           Int
  ldrLeft             Int
  ldrRight            Int
  createdAt           DateTime @default(now())
  energyKwh           Float    @default(0)
  cumulativeEnergyKwh Float    @default(0)

  @@map("ann_readings")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}
